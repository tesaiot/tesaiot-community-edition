# TESAIoT Community Edition - admin-ui build context exclusions
# SPDX-License-Identifier: Apache-2.0
#
# Keep secrets, local state and bulky/irrelevant files OUT of the image build
# context. This shrinks the context, speeds up COPY, and prevents leaking dev
# env files or local node_modules into the image. The multi-stage build runs
# `npm ci` itself, so a host node_modules is never needed.

# Secrets / local env (never bake into an image)
.env
.env.*
*.local

# Dependencies (installed inside the builder via `npm ci`)
node_modules

# Build output (regenerated by the builder stage)
dist
build
.vite
*.tsbuildinfo

# VCS / CI / editor noise
.git
.gitignore
.github
.vscode
.idea

# OS cruft
.DS_Store
Thumbs.db

# Logs and caches
*.log
npm-debug.log*
.cache
coverage

# Docker artifacts themselves
Dockerfile
.dockerignore
