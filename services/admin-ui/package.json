{
  "name": "tesaiot-community-edition-admin-ui",
  "private": true,
  "version": "2026.02-rc.1",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5001 --host",
    "// Build Scripts Documentation": "All builds MUST use 'npm run build' which enforces proper cache clearing",
    "prebuild": "echo '\ud83e\uddf9 Clearing ALL caches...' && rm -rf node_modules/.vite* dist .tsbuildinfo .parcel-cache .turbo tmp/",
    "build:original": "tsc && vite build",
    "build": "npm run prebuild && tsc && vite build",
    "postbuild": "echo '\u2705 Build completed with enhanced cache-busting and version tracking'",
    "build:dev": "npm run prebuild && vite build --mode development",
    "build:prod": "npm run prebuild && vite build --mode production",
    "build:analyze": "npm run prebuild && vite build --mode production -- --analyze",
    "clean": "rm -rf node_modules/.vite* dist .tsbuildinfo .parcel-cache .turbo tmp/ && echo '\ud83e\uddf9 All caches cleared'",
    "lint": "eslint src --fix",
    "format": "prettier --write .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --dir src/features --dir src/services",
    "test:integration": "vitest run --dir src/test/integration",
    "test:e2e": "vitest run --dir src/test/e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:snapshot": "vitest run --dir src/test/snapshots",
    "test:snapshot:capture": "SNAPSHOT_MODE=capture vitest run --dir src/test/snapshots",
    "test:snapshot:watch": "vitest watch --dir src/test/snapshots",
    "test:contracts": "vitest run src/test/contracts/tesaApi.contracts.test.ts",
    "test:contracts:capture": "RECORDING_MODE=capture vitest run src/test/contracts/tesaApi.contracts.test.ts",
    "test:contracts:watch": "vitest watch src/test/contracts/tesaApi.contracts.test.ts",
    "check-circular": "madge --circular --extensions ts,tsx src/",
    "docker:build": "docker build -t tesa-admin-ui-react .",
    "docker:run": "docker run -p 5001:5001 --name tesa-admin-ui-react --rm tesa-admin-ui-react"
  },
