## Quick Start

1. Copy `data_telemetry.h` and `data_telemetry.c` to your firmware project
2. Include the header in your code:
   ```c
   #include "data_telemetry.h"
   ```
3. Use the struct and functions:
   ```c
   telemetry_data_t data;
   char json_buffer[TELEMETRY_MAX_JSON_SIZE];
   int32_t len;

   telemetry_init(&data);

   // Set your sensor values
{% for field in fields %}
{% if field.c_type.value == 'char[]' %}
   TELEMETRY_SET_{{ field.name | upper }}(&data, "your_value");
{% elif field.c_type.value == 'bool' %}
   TELEMETRY_SET_{{ field.name | upper }}(&data, true);
{% elif field.c_type.value in ['float', 'double'] %}
   TELEMETRY_SET_{{ field.name | upper }}(&data, 0.0f);
{% else %}
   TELEMETRY_SET_{{ field.name | upper }}(&data, 0);
{% endif %}
{% endfor %}

   // Convert to JSON
   len = telemetry_to_json(&data, json_buffer, sizeof(json_buffer));
   if (len > 0) {
       mqtt_publish("device/{{ device_id }}/telemetry", json_buffer, len);
   }
   ```

