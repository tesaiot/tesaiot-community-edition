# =============================================================================
# TESAIoT Community Edition - environment template
# SPDX-License-Identifier: Apache-2.0
# Copyright TESAIoT Platform contributors
#
# Copy to .env and replace every CHANGEME value before first boot:
#     cp .env.example .env   (or run: ./scripts/generate-secrets.sh)
#
# NEVER commit the resulting .env - it contains live secrets.
# Single-organization, self-host distribution.
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment identity
# -----------------------------------------------------------------------------
# DOMAIN is the SINGLE SOURCE OF TRUTH for the public hostname. Defaults to
# localhost so the stack runs on a fresh machine with no DNS.
#
# Prefer the --domain flag over editing this by hand:
#     ./scripts/generate-secrets.sh --domain=iot.yourcompany.com   (or: make install DOMAIN=...)
# It re-derives every host-dependent value from DOMAIN — the TLS cert CN/SAN
# (EMQX_CERT_*), the public API/ingest/MQTT URLs (TESA_PUBLIC_*), and the
# onboarding hostnames below (TESA_*_DOMAIN, ADMIN_EMAIL, EMAIL_FROM_ADDRESS) —
# so it propagates everywhere without hand-editing many files. It is idempotent:
# safe to re-run later to switch domains. nginx uses 'server_name _' (any host),
# so it needs no change. Point a DNS A-record at this host before going live.
DOMAIN=localhost
# Single default organization id - the CE build is single-org. Keep as a
# stable constant; do not change after first boot (it is written into data).
DEFAULT_ORG_ID=default-org
TZ=Asia/Bangkok

# Image tag + build metadata (used by docker compose build/up)
BUILD_TAG=latest
CACHEBUST=1
BUILD_DATE=unknown
BUILD_HASH=unknown

# -----------------------------------------------------------------------------
# HashiCorp Vault (PKI + secrets)
# -----------------------------------------------------------------------------
# Populated by generate-secrets.sh / init-vault-pki.sh after the first
# `vault operator init`. Leave blank for a fresh install; the init script fills
# them in. Keep these SECRET.
VAULT_UNSEAL_KEY_1=
VAULT_UNSEAL_KEY_2=
VAULT_UNSEAL_KEY_3=
VAULT_ROOT_TOKEN=CHANGEME_VAULT_ROOT_TOKEN
# Mount path for the issuing (intermediate) PKI engine.
VAULT_PKI_PATH=pki-int
# Vault AppRole credentials the api authenticates with (validated at boot).
# Leave blank: init-vault-pki.sh creates the AppRole and fills these in (it also
# writes the role-id/secret-id files the Vault Agent uses).
API_ROLE_ID=
API_SECRET_ID=

# -----------------------------------------------------------------------------
# MongoDB (device/user/certificate registry)
# -----------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=mongoadmin
MONGO_INITDB_ROOT_PASSWORD=CHANGEME_MONGO_ROOT_PASSWORD
MONGO_INITDB_DATABASE=tesa_iot
# Application user the API connects as (created by init-mongo.js).
MONGODB_USER=iot_user
MONGODB_PASSWORD=CHANGEME_MONGO_APP_PASSWORD
MONGODB_DATABASE=tesa_iot
MONGODB_AUTH_SOURCE=admin

# -----------------------------------------------------------------------------
# TimescaleDB / PostgreSQL (telemetry time-series)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_POSTGRES_PASSWORD
POSTGRES_DB=tesa_telemetry

# -----------------------------------------------------------------------------
# Redis (cache + rate-limit storage)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGEME_REDIS_PASSWORD

# -----------------------------------------------------------------------------
# API service (auth / JWT / bootstrap admin)
# -----------------------------------------------------------------------------
# Symmetric JWT signing secret (HS256). MUST be long & random.
JWT_SECRET=CHANGEME_JWT_SECRET
SECRET_KEY=CHANGEME_FLASK_SECRET_KEY
# bcrypt cost factor (env-driven, never hardcode in code).
BCRYPT_LOG_ROUNDS=12
# Bootstrap administrator created on first boot (single-org admin).
ADMIN_EMAIL=admin@localhost
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGEME_ADMIN_PASSWORD
# Allow the bootstrap admin to bypass per-IP login rate limiting.
ADMIN_BYPASS_RATE_LIMIT=true
LOG_LEVEL=INFO

# Defence-in-depth marker proving a device request traversed the verified mTLS
# terminator (nginx 30-iot-mtls.conf). The mTLS listener injects this value as
# the X-MTLS-Gateway header AFTER verifying the client certificate; the API
# refuses to honour any X-Client-* device header unless it matches. This makes
# X-Client-* header forgery from any other ingress structurally impossible.
# generate-secrets.sh fills this in and substitutes it into the nginx config.
# MUST be long & random; if blank, header-based mTLS auth is disabled (fail-closed).
MTLS_GATEWAY_SECRET=CHANGEME_MTLS_GATEWAY_SECRET

# Public-facing URLs advertised to devices (QR enroll, telemetry ingest).
TESA_PUBLIC_API_BASE_URL=https://localhost
TESA_PUBLIC_INGEST_BASE_URL=https://localhost:9444
TESA_PUBLIC_MQTT_HOST=localhost
TESA_PUBLIC_MQTT_TLS_PORT=8884
TESA_PUBLIC_MQTT_MTLS_PORT=8883
TESA_PUBLIC_MQTT_WS_PORT=8083

# Public hostnames derived from DOMAIN, advertised in onboarding artefacts.
# All default to ${DOMAIN}-derived values and are (re)wired by
# generate-secrets.sh --domain=<your-domain>. Override only if your provisioning
# / admin / MQTT services live on different hostnames.
#   - TESA_MQTT_DOMAIN     : MQTT host baked into device certificate bundles.
#   - TESA_PROVISION_DOMAIN: host in factory-registration QR URLs.
#   - TESA_ADMIN_DOMAIN    : host in account-setup / password-reset email links.
TESA_MQTT_DOMAIN=localhost
TESA_PROVISION_DOMAIN=provision.localhost
TESA_ADMIN_DOMAIN=admin.localhost

# -----------------------------------------------------------------------------
# Email / OTP (optional - user-creation + password-reset mail).
# Leave EMAIL_ENABLED=false to log mail to stdout instead of sending.
# -----------------------------------------------------------------------------
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@localhost
EMAIL_FROM_NAME=TESAIoT Platform
EMAIL_PROVIDER=smtp
RESEND_API_KEY=
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=15
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_SECONDS=30

# -----------------------------------------------------------------------------
# EMQX MQTT broker
# -----------------------------------------------------------------------------
# Web dashboard (http://localhost:18083) admin password.
EMQX_DASHBOARD_PASSWORD=CHANGEME_EMQX_DASHBOARD_PASSWORD
# Shared bearer secret EMQX presents to the API auth/ACL webhooks.
EMQX_WEBHOOK_SECRET=CHANGEME_EMQX_WEBHOOK_SECRET
# Erlang distribution cookie baked into the rendered emqx.conf
# (generate-secrets.sh renders config/emqx/emqx.conf.tpl with this value).
EMQX_NODE_COOKIE=CHANGEME_EMQX_NODE_COOKIE
# Vault-Agent issues the EMQX server cert for these names (defaults to DOMAIN).
# 'tesa-emqx' is the internal Docker DNS name the mqtt-bridge connects to over
# TLS; keep it in the SAN list so the bridge can do full hostname verification
# (MQTT_TLS_VERIFY_HOSTNAME=true). generate-secrets.sh re-adds it on --domain.
EMQX_CERT_CN=localhost
EMQX_CERT_ALT_NAMES=localhost,mqtt.localhost,tesa-emqx
EMQX_CERT_IP_SANS=127.0.0.1

# -----------------------------------------------------------------------------
# MQTT credentials (broker internal users + telemetry bridge)
# -----------------------------------------------------------------------------
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=CHANGEME_MQTT_PASSWORD
# Built-in user used by the telemetry bridge to connect to EMQX.
MQTT_BRIDGE_PASSWORD=CHANGEME_MQTT_BRIDGE_PASSWORD
# Dedicated LEAST-PRIVILEGE service account the bridge logs in as to forward
# telemetry. The API auto-creates it on boot with telemetry-only permissions
# from these two vars (it is NOT the admin account and must never share the
# admin password). generate-secrets.sh derives the user from DOMAIN
# (bridge@<domain>) and gives it its own independently generated password.
BRIDGE_API_USER=bridge@localhost
BRIDGE_API_PASSWORD=CHANGEME_BRIDGE_API_PASSWORD

# -----------------------------------------------------------------------------
# APISIX API gateway (standalone YAML mode - no etcd)
# -----------------------------------------------------------------------------
# Admin API key (provision routes/consumers at runtime). 32+ chars.
APISIX_ADMIN_KEY=CHANGEME_APISIX_ADMIN_KEY
APISIX_ADMIN_URL=http://tesa-apisix:9180/apisix/admin
# Sample static device API-key consumer rendered into apisix.yaml
# (generate-secrets.sh renders config/apisix/apisix.yaml.tpl with this value).
APISIX_SAMPLE_DEVICE_API_KEY=CHANGEME_DEVICE_API_KEY_SAMPLE

# -----------------------------------------------------------------------------
# TLS material (mounted into nginx from ./config/tls - the path is fixed in
# docker-compose.yml, not configurable here).
# generate-secrets.sh writes a first-run self-signed CA + server cert there;
# init-vault-pki.sh appends the Vault client-CA chain and vault-agent issues
# the EMQX server certs. Files: server-cert.pem  server-key.pem  ca-bundle.pem
# -----------------------------------------------------------------------------
